<configuration>
    <!-- Common properties -->
    <property name="LOG_PATH" value="logs" />

    <!-- Console appender (Human readable, used in dev) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{requestId}] [%X{actor}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- App File appender (JSON format for Prod) -->
    <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/application.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <!-- Simple manual JSON encoder since we shouldn't add dependencies -->
            <pattern>{"timestamp":"%d{ISO8601}","level":"%p","requestId":"%X{requestId}","actor":"%X{actor}","logger":"%logger{36}","message":"%replace(%msg){'"', '\\"'}","thread":"%thread"}%n</pattern>
        </encoder>
    </appender>

    <!-- Audit File appender -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/audit.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/audit.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>{"timestamp":"%d{ISO8601}","level":"%p","requestId":"%X{requestId}","actor":"%X{actor}","message":"%replace(%msg){'"', '\\"'}"}%n</pattern>
        </encoder>
    </appender>

    <!-- Security File appender for WARN/ERROR in security/auth -->
    <appender name="SECURITY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/security.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/security.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>{"timestamp":"%d{ISO8601}","level":"%p","requestId":"%X{requestId}","actor":"%X{actor}","logger":"%logger{36}","message":"%replace(%msg){'"', '\\"'}","thread":"%thread"}%n</pattern>
        </encoder>
    </appender>

    <logger name="com.example.daugia.common.audit.AuditServiceImpl" level="INFO" additivity="false">
        <appender-ref ref="AUDIT_FILE" />
    </logger>

    <!-- Route security and auth warnings/errors to SECURITY_FILE -->
    <logger name="com.example.daugia.auth" level="WARN" additivity="false">
        <appender-ref ref="SECURITY_FILE" />
        <appender-ref ref="CONSOLE" />
    </logger>

    <springProfile name="dev">
        <logger name="com.example.daugia" level="DEBUG" />
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <!-- Dev also logs to file but we'll use APP_FILE anyway -->
            <appender-ref ref="APP_FILE" />
        </root>
    </springProfile>

    <springProfile name="!dev">
        <root level="INFO">
            <appender-ref ref="APP_FILE" />
        </root>
    </springProfile>

</configuration>